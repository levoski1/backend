# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
HOST=0.0.0.0
REQUEST_TIMEOUT_MS=30000
RENDER_EXTERNAL_URL=

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Authentication ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ─── Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shelter
DB_USER=shelter_app
DB_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────
# Set REDIS_URL for single-URI connections (e.g. Render Redis).
# Falls back to REDIS_HOST/PORT if REDIS_URL is not set.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── AWS ─────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_MEDIA_BUCKET=shelter-media-development
S3_SIGNED_URL_EXPIRY=3600

# ─── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@shelter.app

# ─── Moderation ──────────────────────────────────────────
CONTENT_MODERATION_ENABLED=true

# ─── OAuth (Google) ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ─── OAuth (Apple) ───────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/apple/callback

# ─── Mobile Deep Link (no trailing slash) ────────────────
MOBILE_DEEP_LINK=myapp-dev://auth/callback

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
