# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
HOST=0.0.0.0
REQUEST_TIMEOUT_MS=30000

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Authentication ──────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string-in-prod
JWT_REFRESH_SECRET=change-me-to-a-random-64-char-string-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ─── Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=shelter
DB_USER=shelter_app
DB_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── AWS ─────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_MEDIA_BUCKET=shelter-media-development
S3_SIGNED_URL_EXPIRY=3600

# ─── Email ───────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@shelter.app

# ─── Moderation ──────────────────────────────────────────
CONTENT_MODERATION_ENABLED=true

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
