# HashiCorp Vault Configuration
VAULT_ENABLED=true
VAULT_URL=https://your-vault-instance.com:8200
VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxx
# OR use AppRole authentication
VAULT_ROLE=your-app-role
VAULT_ROLE_ID=your-role-id
VAULT_SECRET_ID=your-secret-id

# AWS Secrets Manager Configuration (alternative to Vault)
AWS_SECRETS_MANAGER_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Database Configuration (will be fetched from Vault/Secrets Manager)
# These are fallback values if Vault/Secrets Manager is not available
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vesting_vault
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false

# Redis Configuration (will be fetched from Vault/Secrets Manager)
# These are fallback values if Vault/Secrets Manager is not available
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# API Keys (will be fetched from Vault/Secrets Manager)
# These are fallback values if Vault/Secrets Manager is not available
STELLAR_SECRET_KEY=your-stellar-key
SENTRY_DSN=your-sentry-dsn
DISCORD_BOT_TOKEN=your-discord-token
AWS_SES_ACCESS_KEY=your-ses-key
AWS_SES_SECRET_KEY=your-ses-secret

# Vault Secret Paths Examples
# database/host -> "localhost"
# database/port -> "5432"
# database/username -> "postgres"
# database/password -> "password"
# database/name -> "vesting_vault"
# redis/host -> "localhost"
# redis/port -> "6379"
# redis/password -> "your-redis-password"
# api/stellar_key -> "your-stellar-secret-key"
# api/sentry_dsn -> "https://your-sentry-dsn"
# api/discord_token -> "your-discord-bot-token"
# api/ses_key -> "your-ses-access-key"
