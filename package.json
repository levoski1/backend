{
  "name": "@shelter/api",
  "version": "0.1.0",
  "private": true,
  "description": "Shelter API — A Digital Sanctuary for Faith and Mental Health",
  "keywords": [
    "faith",
    "mental-health",
    "community",
    "counseling",
    "prayer"
  ],
  "license": "MIT",
  "author": "Shelter Engineering Team",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:unit": "jest tests/unit",
    "test:int": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:cov": "jest --coverage",
    "db:migrate": "node --import tsx/esm ./node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.cjs",
    "db:migrate:make": "node --import tsx/esm ./node_modules/knex/bin/cli.js migrate:make --knexfile knexfile.cjs",
    "db:rollback": "node --import tsx/esm ./node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.cjs",
    "db:seed": "node --import tsx/esm ./node_modules/knex/bin/cli.js seed:run --knexfile knexfile.cjs",
    "swagger:gen": "NODE_ENV=development tsx scripts/generate-swagger.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.40",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/response-time": "^2.3.9",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "rate-limit-redis": "^5.0.0",
    "response-time": "^2.3.4",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.1",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "pm2": "^7.0.1",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
