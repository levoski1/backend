{
  "name": "@shelter/api",
  "version": "0.1.0",
  "private": true,
  "description": "Shelter API — A Digital Sanctuary for Faith and Mental Health",
  "keywords": ["faith", "mental-health", "community", "counseling", "prayer"],
  "license": "MIT",
  "author": "Shelter Engineering Team",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:unit": "jest tests/unit",
    "test:int": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:cov": "jest --coverage",
    "db:migrate": "knex migrate:latest --knexfile src/infrastructure/database/knexfile.ts",
    "db:rollback": "knex migrate:rollback --knexfile src/infrastructure/database/knexfile.ts",
    "db:seed": "knex seed:run --knexfile src/infrastructure/database/knexfile.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "husky": "^9.1.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.12",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
